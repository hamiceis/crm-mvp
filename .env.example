# ──────────────────────────────────────────────
# CRM Simple — Variáveis de Ambiente
# ──────────────────────────────────────────────
# Copie este arquivo para ".env" e preencha os valores.

# ── Banco de dados ──────────────────────────
# SQLite (atual):
# DATABASE_URL="file:./dev.db"
# PostgreSQL (após migração):
DATABASE_URL="postgresql://user:password@localhost:5432/crm_simple?schema=public"

# ── NextAuth ────────────────────────────────
# Gere com: openssl rand -base64 32
NEXTAUTH_SECRET="sua-secret-key-aqui"
NEXTAUTH_URL="http://localhost:3000"

# ── API de Integração (Lead inbound) ────────
INTEGRATION_API_KEY="chave-secreta-para-integracao"
INTEGRATION_COMPANY_ID=""

# ── Lembretes via WhatsApp ──────────────────
WHATSAPP_API_TOKEN=""
WHATSAPP_PHONE_NUMBER_ID=""
WHATSAPP_TO_NUMBER=""

# ── Cron de task reminders ──────────────────
REMINDER_RUN_KEY="chave-para-disparar-lembretes"

# ── Seed (opcional, padrão: admin@crm.local) ─
SEED_ADMIN_EMAIL="admin@crm.local"
SEED_ADMIN_PASSWORD="Admin@123"
SEED_SALES_EMAIL="vendas@crm.local"
SEED_SALES_PASSWORD="Vendas@123"
